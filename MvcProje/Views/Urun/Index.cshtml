@model List<MvcProje.Models.Urun>
 
<h2>Ürün Listesi</h2>


<button type="button" class="btn btn-success" data-bs-toggle="button" aria-pressed="false" autocomplete="off" >
    +Yeni ürün ekle
</button>





<table class="table">
    <thead>
        <tr>
            <th>Ürün Adı</th>        
            <th>Fiyat</th>        
            <th>Kategori Adı</th>        
        </tr>
    </thead>

    <tbody>
        @foreach (var urun in Model)
        {
            <tr>  
                <td>@urun.Ad</td>
                <td>@urun.Fiyat</td>
                <td>@urun.Kategori.Ad</td>
            </tr>
        }
    </tbody>
</table>